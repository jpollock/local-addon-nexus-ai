{
  "name": "@local-labs-jpollock/local-addon-nexus-ai",
  "productName": "Nexus AI",
  "version": "0.1.3",
  "main": "lib/main.js",
  "renderer": "lib/renderer.js",
  "bin": {
    "nexus": "./bin/nexus.js"
  },
  "localAddon": {
    "minimumLocalVersion": "9.0.0",
    "type": "addon",
    "category": "developer-tools"
  },
  "scripts": {
    "build": "npm run clean && npm run compile && npm run create-entry-points",
    "compile": "tsc -p .",
    "create-entry-points": "node scripts/create-entry-points.js",
    "clean": "rm -rf lib",
    "watch": "tsc -p . --watch",
    "pretest": "npm rebuild better-sqlite3 --silent",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config tests/integration/jest.integration.config.js",
    "test:integration:verbose": "jest --config tests/integration/jest.integration.config.js --verbose",
    "test:e2e": "jest --config tests/e2e/jest.e2e.config.js",
    "test:e2e:verbose": "jest --config tests/e2e/jest.e2e.config.js --verbose",
    "test:e2e:browser": "playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:browser:ui": "playwright test --config tests/e2e/playwright.config.ts --ui",
    "test:e2e:browser:debug": "playwright test --config tests/e2e/playwright.config.ts --debug",
    "pretest:e2e": "echo 'Requires Local running with Nexus AI addon loaded'",
    "test:cli-e2e": "jest --config tests/e2e-cli/jest.cli-e2e.config.js",
    "test:cli-e2e:verbose": "jest --config tests/e2e-cli/jest.cli-e2e.config.js --verbose",
    "pretest:cli-e2e": "echo 'Requires PRODUCTION Local running (/Applications/Local.app)'",
    "test:stress": "jest --config tests/stress/jest.stress.config.js",
    "test:stress:verbose": "jest --config tests/stress/jest.stress.config.js --verbose",
    "test:stress:memory": "node --expose-gc node_modules/.bin/jest --config tests/stress/jest.stress.config.js tests/stress/04-memory-leaks.test.ts",
    "pretest:stress": "echo 'Requires Local running with Nexus AI addon loaded'",
    "test:eval": "jest --config tests/eval/jest.eval.config.js",
    "test:eval:verbose": "jest --config tests/eval/jest.eval.config.js --verbose",
    "test:all": "npm test && npm run test:eval && npm run test:integration && npm run test:e2e",
    "pretest:integration": "npm run download-model",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "download-model": "node scripts/download-model.js",
    "strip": "bash scripts/strip-platforms.sh",
    "package": "node scripts/package-addon.js",
    "package:mac-arm": "node scripts/package-addon.js --platform darwin --arch arm64",
    "package:mac-x64": "node scripts/package-addon.js --platform darwin --arch x64",
    "package:linux-x64": "node scripts/package-addon.js --platform linux --arch x64",
    "package:win-x64": "node scripts/package-addon.js --platform win32 --arch x64",
    "rebuild": "electron-rebuild -v 37.8.0 -f -w better-sqlite3"
  },
  "dependencies": {
    "@getflywheel/local-components": "^17.8.1",
    "@lancedb/lancedb": "^0.13.0",
    "apache-arrow": ">=13.0.0 <=17.0.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^11.1.0",
    "graphql-tag": "^2.12.6",
    "lodash": "^4.17.21",
    "mysql2": "^3.11.0",
    "onnxruntime-node": "^1.20.0",
    "p-limit": "^7.3.0",
    "react-window": "^1.8.10",
    "tar": "^6.2.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-window": "^1.8.8",
    "@types/tar": "^6.1.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@wordpress/e2e-test-utils-playwright": "^1.42.0",
    "dotenv": "^17.3.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "@getflywheel/local": "*",
    "electron": "*",
    "react": "*",
    "react-dom": "*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
