# E2E Test Environment Variables
# Copy to .env.e2e.local and fill in your real keys (gitignored)

# Anthropic (Claude) - for AI provider testing
ANTHROPIC_API_KEY=

# OpenAI - for AI provider testing
OPENAI_API_KEY=

# Google (Gemini) - optional
GOOGLE_API_KEY=

# ACF PRO License Key - optional (for license validation)
ACF_PRO_LICENSE=

# Ollama - auto-detected if running on http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# Disable telemetry during E2E tests (prevents CloudflareTransmitter errors)
NEXUS_TELEMETRY=0
