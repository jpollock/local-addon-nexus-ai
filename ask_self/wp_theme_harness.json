{
  "repo_label": "WordPress Theme",
  "repo_kind": "theme",
  "db_filename": "wp-theme-self-ask.sqlite",
  "system_instructions_path": "ask_self/ask_self_system_instructions.json",
  "env_file_path": "temp/ask-self-rag.env",
  "ingest_command": "python3 ask_self/ask_self_ingest.py --harness-config ask_self/wp_theme_harness.json --mode all",
  "tenancy_env_var": "WP_THEME_SELF_ASK_TEAM_ID",
  "github": {
    "owner": "",
    "repo": "",
    "default_fetch_limit": 200,
    "token_env_vars": [
      "GITHUB_TOKEN"
    ]
  },
  "docs": {
    "extensions": [
      ".md",
      ".txt"
    ],
    "include_patterns": [
      "^(?:README|CHANGELOG|CONTRIBUTING|LICENSE|COPYING)(?:\\.[^/]+)?$",
      "^[^/]+\\.(?:md|txt)$",
      "^docs/.+\\.(?:md|txt)$"
    ],
    "exclude_patterns": [
      "^\\.git/",
      "^node_modules/",
      "^vendor/",
      "^dist/",
      "^build/",
      "^coverage/",
      "^temp/",
      "^scratch/",
      "^\\.venv/"
    ]
  },
  "source": {
    "extensions": [
      ".php",
      ".js",
      ".mjs",
      ".cjs",
      ".ts",
      ".tsx",
      ".jsx",
      ".json",
      ".css",
      ".scss",
      ".html"
    ],
    "include_patterns": [
      "^[^/]+\\.php$",
      "^style\\.css$",
      "^[^/]+\\.scss$",
      "^(?:theme|block)\\.json$",
      "^(?:templates|parts|patterns|woocommerce|blocks|inc|includes|src|app|lib|classes|assets)/.+\\.(?:php|js|mjs|cjs|ts|tsx|jsx|json|css|scss|html)$"
    ],
    "exclude_patterns": [
      "^\\.git/",
      "^node_modules/",
      "^vendor/",
      "^dist/",
      "^build/",
      "^coverage/",
      "^temp/",
      "^scratch/",
      "^\\.venv/",
      "(?:^|/)vendor/",
      "(?:^|/)node_modules/",
      "\\.min\\.(?:js|css)$"
    ]
  },
  "classification_rules": [
    {
      "pattern": "(?i)changelog\\.(?:md|txt)$",
      "source": "changelog",
      "priority": 5,
      "chunker": "changelog"
    },
    {
      "pattern": "^(?:README|readme|CHANGELOG|changelog)\\.(?:md|txt)$",
      "source": "doc",
      "priority": 4,
      "chunker": "text"
    },
    {
      "pattern": "^(?:theme|block)\\.json$|(?:^|/)(?:theme|block)\\.json$",
      "source": "config",
      "priority": 5,
      "chunker": "text"
    },
    {
      "pattern": "^style\\.css$",
      "source": "theme-style",
      "priority": 4,
      "chunker": "line"
    },
    {
      "pattern": "^(?:templates|parts|patterns|woocommerce)/.+\\.(?:php|html)$",
      "source": "template",
      "priority": 4,
      "chunker": "line"
    },
    {
      "pattern": "(?:^|/)tests?/",
      "source": "test",
      "priority": 1,
      "chunker": "line"
    },
    {
      "pattern": "\\.php$",
      "source": "php",
      "priority": 4,
      "chunker": "php"
    },
    {
      "pattern": "\\.(?:js|mjs|cjs|ts|tsx|jsx)$",
      "source": "script",
      "priority": 3,
      "chunker": "line"
    },
    {
      "pattern": "\\.(?:css|scss)$",
      "source": "style",
      "priority": 2,
      "chunker": "line"
    }
  ],
  "default_classification": {
    "source": "doc",
    "priority": 1,
    "chunker": "text"
  }
}
